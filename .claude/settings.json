{
  "permissions": {
    "read": ["src/**/*.java", "src/**/*.yml", "src/**/*.yaml", "src/**/*.xml", "src/**/*.properties", "build.gradle", "settings.gradle", "gradle/**"],
    "write": ["src/**/*.java", "src/**/*.xml", "src/**/*.yml", "src/**/*.yaml"],
    "execute": ["./gradlew", "git", "docker", "kubectl"],
    "network": ["localhost:8080", "localhost:3306", "localhost:6379", "localhost:8848"]
  },
  "hooks": {
    "preCommit": ["echo 'Running pre-commit checks...'", "./gradlew checkstyleMain spotlessCheck"]
  },
  "custom": {
    "projectType": "spring-boot-ddd",
    "jdkVersion": "25",
    "gradleVersion": "9.5"
  }
}
